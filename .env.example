# --- GCP / Vertex AI Search ---
PROJECT_ID=
PROJECT_NUMBER=
LOCATION=global                 # data store location: global | us | eu
DATA_STORE_ID=ge-search-demo    # created by scripts/03_stage_import.py; reused by the app
# Gemini Enterprise (Agentspace) engine/app over the data store. ALL :search and assistant
# (:streamAssist) calls hit THIS engine so traffic is covered by the GE per-seat subscription —
# querying the data store directly (empty ENGINE_ID) bills standalone (SKU 93D6-7280-CF05). Must
# be a genuine GE engine.
ENGINE_ID=ge-search-app
ASSISTANT_ID=default_assistant  # assistant under the GE engine used for :streamAssist
GCS_BUCKET=gs://CHANGEME-ge-search-corpus

# --- Security trimmer (Approach 1 — manual external-DB filtering) ---
PERMISSION_BACKEND=firestore    # firestore (DocumentDB adapter = future)
FIRESTORE_DATABASE=(default)
IDENTITY_SOURCE=demo            # demo (X-Demo-User) | iap (X-Goog-Authenticated-User-Email)

# --- Answer generation ---
# Every answer (result-set, follow-up, per-doc) is generated by the GE engine assistant
# (:streamAssist) over the ACL-trimmed docs — covered by the GE subscription. No model/engine
# knobs: the engine + ASSISTANT_ID above fully determine generation.

# Reranking: the standalone cross-encoder Ranking API (rankingConfigs:rank) is a SEPARATELY-billed
# Vertex AI Search call (not routed through the GE engine), so it's OFF by default to keep all
# traffic under the GE subscription. RERANK_EXTRACTIVE only affects :search result display.
RERANK=off                      # on | off (on = separate ranking charge)
RERANK_EXTRACTIVE=on            # on | off (request extractive segments for result display)

# --- Corpus fetch limits (scripts/01) ---
RESEARCH_LIMIT=30               # max full-text research PDFs to fetch
